{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@/*": ["./*"],
      "@oxyhq/bloom": ["./node_modules/@oxyhq/bloom/lib/typescript/module/index.d.ts"],
      "@oxyhq/bloom/*": ["./node_modules/@oxyhq/bloom/lib/typescript/module/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["node_modules"]
}
